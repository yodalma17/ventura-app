# ─── Servidor ─────────────────────────────────────────────────────────────────
# Railway asigna PORT automáticamente. Localmente usa 4000.
PORT=4000

# Directorio donde se guarda la BD SQLite y los archivos subidos.
# En Railway: crea un Volume en /data y añade esta variable.
# Localmente: déjalo vacío (usará server/data/ por defecto).
DATA_DIR=

# ─── OAuth (opcional, desactivado por defecto) ────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=consumers
